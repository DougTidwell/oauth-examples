{
  "uid": "admins-dashboard",
  "title": "Admin Dashboard",
  "description": "Raw data access and system health \u2014 admins only",
  "tags": [
    "admin"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": false,
  "time": {
    "from": "2024-01-01T00:00:00.000Z",
    "to": "2024-12-31T23:59:59.000Z"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Raw Orders in DB",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT count() AS value FROM raw.orders",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Customers",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT uniq(customer_email) AS value FROM raw.orders",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Unit Cost",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT toFloat64(avg(unit_cost)) AS value FROM raw.orders",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Unit Price",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT toFloat64(avg(unit_price)) AS value FROM raw.orders",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent Raw Orders (with PII \u2014 admin only)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "options": {
        "sortBy": [
          {
            "displayName": "order_date",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "unit_price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "unit_cost"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT order_id, order_date, customer_name, customer_email, product_name, category, quantity, toFloat64(unit_price) AS unit_price, toFloat64(unit_cost)  AS unit_cost, region, channel, status FROM raw.orders ORDER BY order_date DESC, order_id DESC LIMIT 100",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Orders by Region and Status",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "options": {
        "orientation": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT region, countIf(status='completed') AS completed, countIf(status='returned')  AS returned, countIf(status='cancelled') AS cancelled FROM raw.orders GROUP BY region ORDER BY region",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Cost vs Price by Product (margin opportunity)",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "options": {
        "sortBy": [
          {
            "displayName": "margin_pct",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "avg_price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_cost"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "margin_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 0.3
                    },
                    {
                      "color": "green",
                      "value": 0.5
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT product_name, category, toFloat64(avg(unit_price)) AS avg_price, toFloat64(avg(unit_cost))  AS avg_cost, toFloat64(avg((unit_price - unit_cost) / unit_price)) AS margin_pct FROM raw.orders GROUP BY product_name, category ORDER BY margin_pct ASC LIMIT 25",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Daily Order Value by Channel",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 7
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT order_date AS t, toFloat64(sumIf(quantity * unit_price, channel='web'))            AS Web, toFloat64(sumIf(quantity * unit_price, channel='mobile'))         AS Mobile, toFloat64(sumIf(quantity * unit_price, channel='email_campaign')) AS Email FROM raw.orders GROUP BY t ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "timepicker": {
    "hidden": false
  }
}