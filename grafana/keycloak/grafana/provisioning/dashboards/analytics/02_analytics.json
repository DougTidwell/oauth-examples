{
  "uid": "analysts-dashboard",
  "title": "Analytics Dashboard",
  "description": "Detailed analytics \u2014 analysts and admins only",
  "tags": [
    "analytics"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": false,
  "time": {
    "from": "2024-01-01T00:00:00.000Z",
    "to": "2024-12-31T23:59:59.000Z"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Daily Revenue by Region",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT order_date AS t, toFloat64(sumIf(revenue, region='Midwest'))   AS Midwest, toFloat64(sumIf(revenue, region='Northeast')) AS Northeast, toFloat64(sumIf(revenue, region='Southeast')) AS Southeast, toFloat64(sumIf(revenue, region='Southwest')) AS Southwest, toFloat64(sumIf(revenue, region='West'))      AS West FROM analytics.orders WHERE status != 'returned' GROUP BY t ORDER BY t"
        }
      ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Revenue by Category",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 9
      },
      "options": {
        "orientation": "horizontal",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT category, toFloat64(sum(revenue)) AS revenue FROM analytics.orders WHERE status != 'returned' GROUP BY category ORDER BY revenue DESC",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Orders by Channel",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 9
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT countIf(channel='web')            AS Web, countIf(channel='mobile')         AS Mobile, countIf(channel='email_campaign') AS Email FROM analytics.orders",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top Products by Revenue",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 14,
        "h": 10
      },
      "options": {
        "sortBy": [
          {
            "displayName": "revenue",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "revenue"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "margin"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "margin_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT product_name, category, orders, units_sold, toFloat64(revenue) AS revenue, toFloat64(margin)  AS margin, toFloat64(margin_pct) AS margin_pct FROM reports.product_performance ORDER BY revenue DESC LIMIT 20",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Margin % by Category",
      "gridPos": {
        "x": 14,
        "y": 17,
        "w": 10,
        "h": 10
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "minVizHeight": 10,
        "minVizWidth": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.35
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT toFloat64(avgIf(margin_pct, category='Electronics')) AS Electronics, toFloat64(avgIf(margin_pct, category='Office'))       AS Office, toFloat64(avgIf(margin_pct, category='Accessories'))  AS Accessories FROM analytics.orders WHERE status != 'returned'",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Order Volume: Completed vs Returned",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 7
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT order_date AS t, countIf(status='completed') AS completed, countIf(status='returned')  AS returned, countIf(status='cancelled') AS cancelled FROM analytics.orders GROUP BY t ORDER BY t"
        }
      ]
    }
  ],
  "timepicker": {
    "hidden": false
  }
}