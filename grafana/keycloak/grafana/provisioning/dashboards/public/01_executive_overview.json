{
  "uid": "readers-dashboard",
  "title": "Executive Overview",
  "description": "High-level KPIs \u2014 visible to all users",
  "tags": [
    "public"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": false,
  "time": {
    "from": "2024-01-01T00:00:00.000Z",
    "to": "2024-12-31T23:59:59.000Z"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Revenue",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT toFloat64(sum(revenue)) AS value FROM reports.monthly_revenue",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Orders",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT sum(orders) AS value FROM reports.monthly_revenue",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Margin",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "green",
                "value": 0.45
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT avg(margin_pct) AS value FROM reports.monthly_revenue",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Return Rate",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT avg(return_rate) AS value FROM reports.monthly_revenue",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Monthly Revenue by Region",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 14,
        "h": 10
      },
      "options": {
        "orientation": "auto",
        "stacking": "normal",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT order_month, toFloat64(sumIf(revenue, region='Midwest'))   AS Midwest, toFloat64(sumIf(revenue, region='Northeast')) AS Northeast, toFloat64(sumIf(revenue, region='Southeast')) AS Southeast, toFloat64(sumIf(revenue, region='Southwest')) AS Southwest, toFloat64(sumIf(revenue, region='West'))      AS West FROM reports.monthly_revenue GROUP BY order_month ORDER BY order_month",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Revenue by Channel",
      "gridPos": {
        "x": 14,
        "y": 4,
        "w": 10,
        "h": 10
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT toFloat64(sumIf(revenue, channel='web'))            AS Web, toFloat64(sumIf(revenue, channel='mobile'))         AS Mobile, toFloat64(sumIf(revenue, channel='email_campaign')) AS Email FROM reports.channel_summary",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Revenue by Category",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "options": {
        "sortBy": [
          {
            "displayName": "revenue",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "margin_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "return_rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "rawQuery": true,
          "query": "SELECT category, toFloat64(sum(revenue))     AS revenue, toFloat64(avg(margin_pct))  AS margin_pct, toFloat64(avg(return_rate)) AS return_rate FROM reports.monthly_revenue GROUP BY category ORDER BY revenue DESC",
          "format": "table"
        }
      ]
    }
  ],
  "timepicker": {
    "hidden": false
  }
}