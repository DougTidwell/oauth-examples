<clickhouse>
    <startup_scripts>

        <!-- ============================================================
             ROLES
             Keycloak groups map to these via roles_transform (- → _):
               clickhouse-admins   → clickhouse_admins
               clickhouse-analysts → clickhouse_analysts
               clickhouse-readers  → clickhouse_readers (also common_role)
             ============================================================ -->

        <scripts>
            <query>CREATE ROLE OR REPLACE clickhouse_readers</query>
        </scripts>
        <scripts>
            <query>CREATE ROLE OR REPLACE clickhouse_analysts</query>
        </scripts>
        <scripts>
            <query>CREATE ROLE OR REPLACE clickhouse_admins</query>
        </scripts>
        <!-- reader_role is the common_role given to all token users -->
        <scripts>
            <query>CREATE ROLE OR REPLACE reader_role</query>
        </scripts>

        <!-- ============================================================
             GRANTS
             reports db  → readers (and up)
             analytics db → analysts + admins
             raw db       → admins only
             ============================================================ -->

        <!-- reader_role (everyone): reports db only -->
        <scripts>
            <query>GRANT SELECT ON reports.* TO reader_role</query>
        </scripts>

        <!-- clickhouse_readers: same as reader_role (belt + suspenders) -->
        <scripts>
            <query>GRANT reader_role TO clickhouse_readers</query>
        </scripts>

        <!-- clickhouse_analysts: reports + analytics -->
        <scripts>
            <query>GRANT reader_role TO clickhouse_analysts</query>
        </scripts>
        <scripts>
            <query>GRANT SELECT ON analytics.* TO clickhouse_analysts</query>
        </scripts>

        <!-- clickhouse_admins: everything -->
        <scripts>
            <query>GRANT clickhouse_analysts TO clickhouse_admins</query>
        </scripts>
        <scripts>
            <query>GRANT SELECT ON raw.* TO clickhouse_admins</query>
        </scripts>
        <scripts>
            <query>GRANT SELECT ON system.query_log TO clickhouse_admins</query>
        </scripts>
        <scripts>
            <query>GRANT SELECT ON system.processes TO clickhouse_admins</query>
        </scripts>

        <!-- ============================================================
             PRIYA — a native ClickHouse user
             
             As a password-auth user, priya has reader_role only (reports.*).
             When priya authenticates via JWT token instead, Keycloak says she
             belongs to clickhouse-analysts, so she gets clickhouse_analysts
             (reports.* + analytics.*).
             
             This demonstrates that the same person gets different access
             depending on HOW they authenticate — password vs token.
             ============================================================ -->
        <scripts>
            <query>CREATE USER IF NOT EXISTS priya IDENTIFIED BY 'priya'</query>
        </scripts>
        <scripts>
            <query>GRANT reader_role TO priya</query>
        </scripts>

    </startup_scripts>
</clickhouse>
