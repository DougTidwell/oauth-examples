      "path": "/clickhouse-readers"
    },
    {
      "name": "grafana-admins",
      "path": "/grafana-admins"
    },
    {
      "name": "grafana-editors",
      "path": "/grafana-editors"
    },
    {
      "name": "grafana-viewers",
      "path": "/grafana-viewers"
    }
  ],
  "users": [
