        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "groups": [
        "/clickhouse-analysts",
        "/grafana-editors"
      ]
    },
    {
      "username": "carol",
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "Reader",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "carol",
          "temporary": false
        }
      ],
      "groups": [
        "/clickhouse-readers",
        "/grafana-viewers"
      ]
    },
    {
      "username": "demo",
      "email": "demo@example.com",
      "firstName": "Demo",
